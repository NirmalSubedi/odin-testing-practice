{
  "name": "testing-practice",
  "version": "1.0.0",
  "description": "Testing Practice",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "watch": "jest --watch *.test.js",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "check": "npm run lint && npm run format",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": [
      "eslint",
      "prettier --write --ignore-unknown",
      "jest --passWithNoTests"
    ]
  },
  "keywords": [],
  "author": "Nirmal Subedi",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1"
  }
}
